<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ═══════════════════════════════════════════════════════════════
         Raccoon File Manager — Light Mode Color System
         Brand: Forest green (#247A58) + Warm amber (#E8861F)
         Philosophy: Chromatic warm surfaces, never neutral gray
         Perceptual model: OKLCH for lightness steps, warm hue bias
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Primary: Deep forest green — woodland raccoon identity ── -->
    <color name="colorPrimary">#247A58</color>
    <color name="colorPrimaryDark">#165740</color>
    <color name="colorPrimaryLight">#3DA87D</color>
    <color name="colorPrimaryContainer">#C8EDD9</color>
    <color name="colorOnPrimaryContainer">#082818</color>
    <color name="colorOnPrimary">#FFFFFF</color>

    <!-- ── Accent: Warm amber — raccoon energy ── -->
    <color name="colorAccent">#E8861F</color>
    <color name="colorAccentLight">#FBE6CF</color>
    <color name="colorOnAccent">#FFFFFF</color>
    <color name="colorAccentContainer">#FDECD8</color>
    <color name="colorOnAccentContainer">#3D2008</color>

    <!-- ── Semantic — warm-shifted to stay on-character (§DC1, §DC5) ── -->
    <color name="colorError">#BF3026</color>
    <color name="colorErrorLight">#FDEAE7</color>
    <color name="colorOnError">#FFFFFF</color>
    <color name="colorSuccess">#2E7D42</color>
    <color name="colorSuccessLight">#E6F5EA</color>
    <color name="colorOnSuccess">#FFFFFF</color>
    <color name="colorWarning">#996D12</color>
    <color name="colorWarningLight">#FFF8E6</color>
    <color name="colorOnWarning">#FFFFFF</color>

    <!-- ── Threat severity scale (antivirus cards, §DC1) ── -->
    <color name="severityCritical">#BF3026</color>
    <color name="severityCriticalLight">#FDEAE7</color>
    <color name="severityHigh">#C05E0A</color>
    <color name="severityHighLight">#FDF0E2</color>
    <color name="severityMedium">#996D12</color>
    <color name="severityMediumLight">#FFF8E6</color>
    <color name="severityLow">#2E7D42</color>
    <color name="severityLowLight">#E6F5EA</color>

    <!-- ── Surface elevation ladder (chromatic warm-whites, §DC3) ──
         Consistent ~3% OKLCH lightness steps:
         surfaceDim(L89) → surfaceBase(L93) → surfaceColor(L97) → surfaceElevated(L99) -->
    <color name="surfaceDim">#E6E2DA</color>
    <color name="surfaceBase">#F0EDE7</color>
    <color name="surfaceColor">#FAF8F4</color>
    <color name="surfaceElevated">#FFFFFB</color>

    <!-- ── Material 3 surface container hierarchy (§DC3) ──
         Maps to M3 surface container roles for layered UI
         Lowest(L99) → Low(L96) → Mid(L93) → High(L90) → Highest(L87) -->
    <color name="surfaceContainerLowest">#FFFFFB</color>
    <color name="surfaceContainerLow">#F7F4EE</color>
    <color name="surfaceContainer">#F0EDE7</color>
    <color name="surfaceContainerHigh">#EAE6DF</color>
    <color name="surfaceContainerHighest">#E4E0D8</color>

    <!-- ── Text hierarchy (chromatic green-tinted, not pure gray, §DC5) ── -->
    <color name="textPrimary">#161816</color>
    <color name="textSecondary">#4B524E</color>
    <color name="textTertiary">#616966</color>
    <color name="textOnPrimary">#FFFFFF</color>
    <color name="textDisabled">#B0B5B2</color>

