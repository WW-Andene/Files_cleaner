<?xml version="1.0" encoding="utf-8"?>
<!-- Shared element return transition — faster exit timing (160ms).
     §DM2: Exits use accelerate (fast_out_linear_in) and are faster than entries. -->
<transitionSet xmlns:android="http://schemas.android.com/apk/res/android"
    android:transitionOrdering="together"
    android:duration="@integer/motion_exit"
    android:interpolator="@android:interpolator/fast_out_linear_in">

    <changeBounds />

    <changeTransform />

    <changeClipBounds />

    <changeImageTransform />

    <fade
        android:fadingMode="fade_out"
        android:duration="@integer/motion_micro" />
</transitionSet>
