<?xml version="1.0" encoding="utf-8"?>
<!-- Shared element enter transition — for list-item-to-detail screen transitions.
     §DM2: Uses motion_page (280ms) with custom fast_out_slow_in for "considerate utility".
     Includes fade for smoother visual continuity when bounds change. -->
<transitionSet xmlns:android="http://schemas.android.com/apk/res/android"
    android:transitionOrdering="together"
    android:duration="@integer/motion_page"
    android:interpolator="@interpolator/fast_out_slow_in_custom">

    <changeBounds />

    <changeTransform />

    <changeClipBounds />

    <changeImageTransform />

    <fade
        android:fadingMode="fade_in"
        android:duration="@integer/motion_enter" />
</transitionSet>
