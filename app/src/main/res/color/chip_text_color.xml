<?xml version="1.0" encoding="utf-8"?>
<!-- Chip text color — covers checked, disabled states.
     §DC4: Disabled text uses textDisabled for clear inactive affordance. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="@color/textDisabled" android:state_enabled="false" />
    <item android:color="@color/colorOnPrimaryContainer" android:state_checked="true" />
    <item android:color="@color/textSecondary" />
</selector>
