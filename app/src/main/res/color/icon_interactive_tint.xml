<?xml version="1.0" encoding="utf-8"?>
<!-- Interactive icon tint — primary when active/pressed, tertiary when default.
     §DC4: Full state coverage including disabled and focused for accessibility. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="@color/textDisabled" android:state_enabled="false" />
    <item android:color="@color/colorPrimary" android:state_activated="true" />
    <item android:color="@color/colorPrimary" android:state_selected="true" />
    <item android:color="@color/colorPrimary" android:state_pressed="true" />
    <item android:color="@color/colorPrimary" android:state_focused="true" />
    <item android:color="@color/textTertiary" />
</selector>
