<?xml version="1.0" encoding="utf-8"?>
<!-- Chip stroke color — covers checked, focused, disabled states.
     §DC4: Focus state uses borderFocus for accessibility ring visibility. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="@color/borderSubtle" android:state_enabled="false" />
    <item android:color="@color/colorPrimary" android:state_checked="true" />
    <item android:color="@color/borderFocus" android:state_focused="true" />
    <item android:color="@color/borderSubtle" />
</selector>
