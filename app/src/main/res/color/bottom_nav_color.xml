<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom navigation icon/text tint — covers checked, pressed, disabled states.
     §DC4: Active tab uses primary brand green, inactive uses tertiary text. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="@color/textDisabled" android:state_enabled="false" />
    <item android:color="@color/colorPrimary" android:state_checked="true" android:state_pressed="true" />
    <item android:color="@color/colorPrimary" android:state_checked="true" />
    <item android:color="@color/textSecondary" android:state_pressed="true" />
    <item android:color="@color/textTertiary" />
</selector>
