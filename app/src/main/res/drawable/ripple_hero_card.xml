<?xml version="1.0" encoding="utf-8"?>
<!-- Hero card ripple — white-tinted for on-primary surfaces.
     §DC4: Uses named color reference instead of hardcoded hex. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/rippleOnPrimary">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white" />
            <corners android:radius="@dimen/radius_header" />
        </shape>
    </item>
</ripple>
