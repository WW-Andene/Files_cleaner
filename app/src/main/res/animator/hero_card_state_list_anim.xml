<?xml version="1.0" encoding="utf-8"?>
<!-- Hero card press/focus feedback — more dramatic elevation for primary CTA.
     §DM1: Uses motion_micro (120ms) for immediate tactile response. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dragged: maximum lift -->
    <item android:state_drag_hovered="true">
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="@integer/motion_micro"
                android:valueTo="8dp"
                android:valueType="floatType" />
        </set>
    </item>
    <!-- Pressed: flatten for tactile "pushed in" feel -->
    <item android:state_pressed="true">
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="@integer/motion_micro"
                android:valueTo="0dp"
                android:valueType="floatType" />
        </set>
    </item>
    <!-- Focused: moderate lift for keyboard/accessibility navigation -->
    <item android:state_focused="true">
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="@integer/motion_micro"
                android:valueTo="6dp"
                android:valueType="floatType" />
        </set>
    </item>
    <!-- Default: resting elevation -->
    <item>
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="@integer/motion_micro"
                android:valueTo="4dp"
                android:valueType="floatType" />
        </set>
    </item>
</selector>
