<?xml version="1.0" encoding="utf-8"?>
<!-- §DM1: Item entrance — slide up + fade in, brisk but considered, uses motion_enter vocabulary.
     Uses custom fast_out_slow_in for "considerate utility" deceleration. Fade slightly shorter
     than translate so content is visible before settling into position. -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@interpolator/fast_out_slow_in_custom">

    <translate
        android:fromYDelta="12%p"
        android:toYDelta="0"
        android:duration="@integer/motion_enter" />

    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:duration="@integer/motion_micro" />
</set>
