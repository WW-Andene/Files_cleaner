<?xml version="1.0" encoding="utf-8"?>
<!-- Success celebration — scale up with gentle overshoot + fade, for operation completion moments -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@interpolator/overshoot_gentle">

    <scale
        android:fromXScale="0.3"
        android:toXScale="1.0"
        android:fromYScale="0.3"
        android:toYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%"
        android:duration="@integer/motion_emphasis" />

    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:duration="@integer/motion_enter" />
</set>
