<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/tree_node_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="@dimen/spacing_xs"
    android:paddingEnd="@dimen/spacing_sm"
    android:background="?attr/selectableItemBackground"
    android:minHeight="@dimen/spacing_4xl">

    <!-- Expand/collapse indicator -->
    <ImageView
        android:id="@+id/iv_expand"
        android:layout_width="@dimen/icon_inline"
        android:layout_height="@dimen/icon_inline"
        android:src="@drawable/ic_chevron_right"
        android:scaleType="centerInside"
        android:importantForAccessibility="no"
        app:tint="@color/textTertiary" />

    <ImageView
        android:id="@+id/iv_folder_icon"
        android:layout_width="@dimen/icon_tree_node"
        android:layout_height="@dimen/icon_tree_node"
        android:src="@drawable/ic_folder"
        android:scaleType="centerInside"
        android:layout_marginStart="@dimen/spacing_micro"
        android:importantForAccessibility="no"
        app:tint="@color/textSecondary" />

    <TextView
        android:id="@+id/tv_node_name"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
        android:textColor="@color/textPrimary"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginStart="@dimen/spacing_xs" />

    <TextView
        android:id="@+id/tv_node_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.FileCleaner.Numeric"
        android:textColor="@color/textTertiary"
        android:singleLine="true"
        android:layout_marginStart="@dimen/spacing_xs" />
</LinearLayout>
