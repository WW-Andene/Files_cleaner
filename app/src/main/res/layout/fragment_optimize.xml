<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfaceBase">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_sm"
            android:minHeight="@dimen/touch_target_min">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="@dimen/icon_button"
                android:layout_height="@dimen/icon_button"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                app:tint="@color/textPrimary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="@string/optimize_title"
                android:textAppearance="@style/TextAppearance.FileCleaner.Title"
                android:accessibilityHeading="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reanalyze"
                style="@style/Widget.FileCleaner.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height_sm"
                android:text="@string/optimize_reanalyze"
                android:textAllCaps="false"
                android:textColor="@color/colorPrimary"
                android:minWidth="@dimen/button_height"
                android:minHeight="@dimen/button_height_sm"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/a11y_reanalyze" />
        </LinearLayout>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progress_analyzing"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_xs"
            android:indeterminate="true"
            android:indeterminateTint="@color/colorPrimary"
            android:visibility="gone"
            android:contentDescription="@string/a11y_analyzing_progress"
            android:accessibilityLiveRegion="assertive" />

        <!-- Explanatory card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardCornerRadius="@dimen/radius_header"
            app:cardElevation="@dimen/elevation_none"
            app:cardBackgroundColor="@color/colorPrimaryContainer"
            app:strokeWidth="@dimen/stroke_none"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/optimize_info_title"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Title"
                    android:textColor="@color/colorOnPrimaryContainer"
                    android:accessibilityHeading="true" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/optimize_info_body"
                    android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                    android:textColor="@color/colorOnPrimaryContainer"
                    android:alpha="0.85" />

                <!-- Select All / Deselect All -->
                <LinearLayout
                    android:id="@+id/selection_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_select_all"
                        style="@style/Widget.FileCleaner.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_sm"
                        android:text="@string/select_all"
                        android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:strokeColor="@color/colorOnPrimaryContainer"
                        android:textColor="@color/colorOnPrimaryContainer"
                        app:cornerRadius="@dimen/radius_pill" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_deselect_all"
                        style="@style/Widget.FileCleaner.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_sm"
                        android:text="@string/deselect_all"
                        android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:strokeColor="@color/colorOnPrimaryContainer"
                        android:textColor="@color/colorOnPrimaryContainer"
                        app:cornerRadius="@dimen/radius_pill" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick filter toggles -->
        <LinearLayout
            android:id="@+id/filter_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_sm"
            android:visibility="gone"
            android:contentDescription="@string/a11y_filter_options">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_old_files"
                style="@style/Widget.FileCleaner.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_old_files"
                android:layout_marginEnd="@dimen/spacing_sm"
                app:chipBackgroundColor="@color/surfaceColor"
                app:chipStrokeColor="@color/borderDefault"
                app:chipStrokeWidth="@dimen/stroke_default"
                app:checkedIconVisible="true"
                app:chipCornerRadius="@dimen/radius_pill" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_large_files"
                style="@style/Widget.FileCleaner.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_large_files"
                app:chipBackgroundColor="@color/surfaceColor"
                app:chipStrokeColor="@color/borderDefault"
                app:chipStrokeWidth="@dimen/stroke_default"
                app:checkedIconVisible="true"
                app:chipCornerRadius="@dimen/radius_pill" />
        </LinearLayout>

        <!-- Summary -->
        <TextView
            android:id="@+id/tv_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_sm"
            android:textAppearance="@style/TextAppearance.FileCleaner.Body"
            android:textColor="@color/textSecondary"
            android:accessibilityLiveRegion="polite" />

        <!-- Suggestions list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_suggestions"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:layoutAnimation="@anim/layout_item_stagger"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_bottom_inset" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/spacing_4xl"
            android:visibility="gone"
            android:contentDescription="@string/a11y_empty_state"
            android:focusable="true"
            android:accessibilityLiveRegion="polite">

            <ImageView
                android:layout_width="@dimen/icon_empty_state"
                android:layout_height="@dimen/icon_empty_state"
                android:src="@drawable/ic_raccoon_logo"
                android:alpha="0.85"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tv_empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/optimize_empty"
                android:textAppearance="@style/TextAppearance.FileCleaner.Body"
                android:textColor="@color/textSecondary"
                android:gravity="center"
                android:lineSpacingExtra="@dimen/spacing_xs" />
        </LinearLayout>

        <!-- Apply button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_apply"
            style="@style/Widget.FileCleaner.Button"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:layout_gravity="center_horizontal"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_bottom_inset"
            android:minWidth="@dimen/button_min_width"
            android:paddingHorizontal="@dimen/spacing_3xl"
            android:text="@string/optimize_apply"
            android:textAllCaps="false"
            android:textAppearance="@style/TextAppearance.FileCleaner.BodyMedium"
            app:cornerRadius="@dimen/radius_btn" />

    </LinearLayout>

    <!-- Floating selection summary bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/selection_summary_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:layout_marginBottom="@dimen/spacing_bottom_inset"
        app:cardCornerRadius="@dimen/radius_card"
        app:cardElevation="@dimen/elevation_raised"
        app:cardBackgroundColor="@color/colorPrimary"
        app:strokeWidth="@dimen/stroke_none"
        android:visibility="gone"
        android:accessibilityLiveRegion="polite"
        android:contentDescription="@string/a11y_selection_actions"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_md"
            android:minHeight="@dimen/touch_target_min">

            <TextView
                android:id="@+id/tv_selection_summary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.FileCleaner.BodyMedium"
                android:textColor="@color/textOnPrimary"
                android:accessibilityLiveRegion="polite" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear_selection"
                style="@style/Widget.FileCleaner.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height_sm"
                android:text="@string/clear_selection"
                android:textColor="@color/textOnPrimary"
                android:textAllCaps="false"
                android:minWidth="@dimen/button_height"
                android:minHeight="@dimen/button_height_sm"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:contentDescription="@string/a11y_clear_selection" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
