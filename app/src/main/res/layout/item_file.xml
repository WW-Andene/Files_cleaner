<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_sm"
    android:layout_marginVertical="@dimen/spacing_xs"
    app:cardCornerRadius="@dimen/radius_card"
    app:cardElevation="@dimen/elevation_subtle"
    app:cardBackgroundColor="@color/surfaceColor"
    app:strokeWidth="@dimen/stroke_default"
    app:strokeColor="@color/borderSubtle"
    app:rippleColor="@color/colorPrimaryContainer"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Color accent stripe (4dp left edge indicator) -->
        <View
            android:id="@+id/view_accent_stripe"
            android:layout_width="@dimen/divider_thick"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_10">

            <!-- Thumbnail / icon -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/icon_provider_container"
                android:layout_height="@dimen/icon_provider_container"
                app:cardCornerRadius="@dimen/radius_icon_container"
                app:cardElevation="@dimen/elevation_none"
                app:strokeWidth="@dimen/stroke_none"
                app:cardBackgroundColor="@color/surfaceDim">

                <ImageView
                    android:id="@+id/iv_file_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:padding="@dimen/spacing_sm"
                    android:importantForAccessibility="no" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Text block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tv_file_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.FileCleaner.BodyMedium"
                    android:textColor="@color/textPrimary"
                    android:maxLines="1"
                    android:ellipsize="middle" />

                <TextView
                    android:id="@+id/tv_file_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                    android:layout_marginTop="@dimen/spacing_micro" />

            </LinearLayout>

            <!-- Checkbox -->
            <CheckBox
                android:id="@+id/cb_select"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="@dimen/button_height"
                android:minHeight="@dimen/button_height"
                android:clickable="false"
                android:buttonTint="@color/colorPrimary"
                android:contentDescription="@string/a11y_select_checkbox" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
