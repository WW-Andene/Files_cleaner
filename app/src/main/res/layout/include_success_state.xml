<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable success/completion state: shows after a clean/scan/operation completes -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingHorizontal="@dimen/spacing_3xl"
    android:paddingTop="@dimen/spacing_5xl"
    android:paddingBottom="@dimen/spacing_4xl"
    android:visibility="gone"
    android:accessibilityLiveRegion="polite">

    <!-- Animated check circle: celebration moment -->
    <ImageView
        android:id="@+id/iv_success_icon"
        android:layout_width="@dimen/icon_empty_state"
        android:layout_height="@dimen/icon_empty_state"
        android:src="@drawable/ic_check_circle"
        app:tint="@color/colorSuccess"
        android:contentDescription="@string/a11y_success"
        android:importantForAccessibility="yes" />

    <TextView
        android:id="@+id/tv_success_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xxl"
        android:textAppearance="@style/TextAppearance.FileCleaner.Title"
        android:textColor="@color/textPrimary"
        android:gravity="center"
        android:maxWidth="@dimen/content_max_width_narrow"
        android:lineSpacingExtra="@dimen/spacing_xs" />

    <TextView
        android:id="@+id/tv_success_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:textAppearance="@style/TextAppearance.FileCleaner.Body"
        android:textColor="@color/textSecondary"
        android:gravity="center"
        android:maxWidth="@dimen/content_max_width_medium"
        android:lineSpacingExtra="@dimen/spacing_xs" />
</LinearLayout>
