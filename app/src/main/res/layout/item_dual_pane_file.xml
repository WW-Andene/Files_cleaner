<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="@dimen/spacing_sm"
    android:paddingVertical="@dimen/spacing_xs"
    android:background="?attr/selectableItemBackground"
    android:minHeight="@dimen/touch_target_min">

    <CheckBox
        android:id="@+id/cb_select"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/touch_target_min"
        android:minHeight="@dimen/touch_target_min"
        android:clickable="false"
        android:buttonTint="@color/colorPrimary"
        android:contentDescription="@string/a11y_select_checkbox"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="@dimen/touch_target_min"
        android:layout_height="@dimen/touch_target_min"
        android:layout_gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="@dimen/icon_dual_pane"
            android:layout_height="@dimen/icon_dual_pane"
            android:layout_gravity="center"
            android:scaleType="centerInside"
            android:importantForAccessibility="no"
            android:contentDescription="@string/a11y_file_type_icon"
            app:tint="@color/textSecondary" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/spacing_xs">

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
            android:textColor="@color/textPrimary"
            android:maxLines="1"
            android:ellipsize="middle" />

        <TextView
            android:id="@+id/tv_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.FileCleaner.Numeric"
            android:textColor="@color/textTertiary"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Chevron for directories -->
    <FrameLayout
        android:layout_width="@dimen/touch_target_min"
        android:layout_height="@dimen/touch_target_min"
        android:layout_gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_chevron"
            android:layout_width="@dimen/icon_small"
            android:layout_height="@dimen/icon_small"
            android:layout_gravity="center"
            android:src="@drawable/ic_chevron_right"
            android:scaleType="centerInside"
            android:visibility="gone"
            android:importantForAccessibility="no"
            android:contentDescription="@string/collapse_expand"
            app:tint="@color/textTertiary" />
    </FrameLayout>
</LinearLayout>
