<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfaceBase"
    android:clipToPadding="false"
    android:paddingBottom="@dimen/spacing_above_nav"
    android:fillViewport="true">

    <!-- F-056: Use screen_horizontal_padding for tablet-aware horizontal inset -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="@dimen/screen_horizontal_padding"
        android:paddingRight="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- Header with raccoon branding — larger, more prominent -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_xl">

            <ImageView
                android:id="@+id/iv_raccoon_avatar"
                android:layout_width="@dimen/icon_raccoon"
                android:layout_height="@dimen/icon_raccoon"
                android:src="@drawable/ic_raccoon_logo"
                android:scaleType="fitCenter"
                android:importantForAccessibility="no" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/raccoon_manager_title"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Headline"
                    android:textColor="@color/textPrimary"
                    android:accessibilityHeading="true" />

                <TextView
                    android:id="@+id/tv_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/raccoon_manager_subtitle"
                    android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                    android:textColor="@color/textSecondary"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:accessibilityLiveRegion="polite" />
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_scan"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:indeterminateTint="@color/colorPrimary"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:contentDescription="@string/a11y_scan_progress"
            android:accessibilityLiveRegion="polite" />

        <!-- Scan Storage card — hero gradient -->
        <!-- F-051: Hero card total elevation = cardElevation (4dp) + translationZ from stateListAnimator
             Resting: 4dp+2dp=6dp, Pressed: 4dp+0dp=4dp, Focused: 4dp+4dp=8dp, Dragged: 4dp+6dp=10dp -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_scan"
            style="@style/Widget.FileCleaner.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:minHeight="@dimen/card_min_height"
            android:foreground="@drawable/ripple_hero_card"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusDown="@id/card_analysis"
            android:stateListAnimator="@animator/hero_card_state_list_anim"
            android:contentDescription="@string/raccoon_action_scan"
            app:cardCornerRadius="@dimen/radius_header"
            app:cardElevation="@dimen/elevation_raised"
            app:cardBackgroundColor="@color/heroCardStart"
            app:strokeWidth="@dimen/stroke_none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_hero_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_xl">

                <ImageView
                    android:layout_width="@dimen/icon_hub_circle"
                    android:layout_height="@dimen/icon_hub_circle"
                    android:src="@drawable/ic_scan"
                    android:scaleType="centerInside"
                    android:importantForAccessibility="no"
                    app:tint="@color/textOnPrimary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:layout_marginStart="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/raccoon_action_scan"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Title"
                        android:textColor="@color/textOnPrimary"
                        android:accessibilityHeading="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/raccoon_action_scan_desc"
                        android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                        android:textColor="@color/textOnPrimary"
                        android:alpha="@dimen/alpha_raccoon_logo"
                        android:layout_marginTop="@dimen/spacing_xs" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_nav"
                    android:layout_height="@dimen/icon_nav"
                    android:src="@drawable/ic_chevron_right"
                    android:importantForAccessibility="no"
                    app:tint="@color/textOnPrimary"
                    android:alpha="@dimen/alpha_text_emphasis" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Analysis card — unique amber tint icon -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_analysis"
            style="@style/Widget.FileCleaner.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:minHeight="@dimen/card_min_height"
            android:foreground="@drawable/ripple_card"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusUp="@id/card_scan"
            android:nextFocusDown="@id/card_quick_clean"
            android:stateListAnimator="@animator/card_state_list_anim"
            android:contentDescription="@string/raccoon_action_analysis">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_lg">

                <FrameLayout
                    android:layout_width="@dimen/icon_hub_circle"
                    android:layout_height="@dimen/icon_hub_circle"
                    android:background="@drawable/bg_hub_icon_circle"
                    android:backgroundTint="@color/tintAnalysis"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="@dimen/hub_card_icon_inner"
                        android:layout_height="@dimen/hub_card_icon_inner"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_dashboard"
                        android:scaleType="centerInside"
                        android:importantForAccessibility="no"
                        app:tint="@color/accentOnTintAnalysis" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:layout_marginStart="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/raccoon_action_analysis"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                        android:textColor="@color/textPrimary"
                        android:accessibilityHeading="true" />

                    <TextView
                        android:id="@+id/tv_analysis_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/raccoon_action_analysis_desc"
                        android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:accessibilityLiveRegion="polite" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_nav"
                    android:layout_height="@dimen/icon_nav"
                    android:src="@drawable/ic_chevron_right"
                    android:importantForAccessibility="no"
                    app:tint="@color/textTertiary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick Clean card — red tint icon -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_quick_clean"
            style="@style/Widget.FileCleaner.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:minHeight="@dimen/card_min_height"
            android:foreground="@drawable/ripple_card"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusUp="@id/card_analysis"
            android:nextFocusDown="@id/card_janitor"
            android:stateListAnimator="@animator/card_state_list_anim"
            android:contentDescription="@string/raccoon_action_quick_clean">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_lg">

                <FrameLayout
                    android:layout_width="@dimen/icon_hub_circle"
                    android:layout_height="@dimen/icon_hub_circle"
                    android:background="@drawable/bg_hub_icon_circle"
                    android:backgroundTint="@color/tintQuickClean"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="@dimen/hub_card_icon_inner"
                        android:layout_height="@dimen/hub_card_icon_inner"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_nav_junk"
                        android:scaleType="centerInside"
                        android:importantForAccessibility="no"
                        app:tint="@color/colorError" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:layout_marginStart="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/raccoon_action_quick_clean"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                        android:textColor="@color/textPrimary"
                        android:accessibilityHeading="true" />

                    <TextView
                        android:id="@+id/tv_quick_clean_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/raccoon_action_quick_clean_desc"
                        android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:accessibilityLiveRegion="polite" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_nav"
                    android:layout_height="@dimen/icon_nav"
                    android:src="@drawable/ic_chevron_right"
                    android:importantForAccessibility="no"
                    app:tint="@color/textTertiary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Janitor card — blue tint icon -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_janitor"
            style="@style/Widget.FileCleaner.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:minHeight="@dimen/card_min_height"
            android:foreground="@drawable/ripple_card"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusUp="@id/card_quick_clean"
            android:nextFocusDown="@id/card_optimize"
            android:stateListAnimator="@animator/card_state_list_anim"
            android:contentDescription="@string/raccoon_action_janitor">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_lg">

                <FrameLayout
                    android:layout_width="@dimen/icon_hub_circle"
                    android:layout_height="@dimen/icon_hub_circle"
                    android:background="@drawable/bg_hub_icon_circle"
                    android:backgroundTint="@color/tintJanitor"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="@dimen/hub_card_icon_inner"
                        android:layout_height="@dimen/hub_card_icon_inner"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_janitor"
                        android:scaleType="centerInside"
                        android:importantForAccessibility="no"
                        app:tint="@color/accentOnTintJanitor" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:layout_marginStart="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/raccoon_action_janitor"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                        android:textColor="@color/textPrimary"
                        android:accessibilityHeading="true" />

                    <TextView
                        android:id="@+id/tv_janitor_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/raccoon_action_janitor_desc"
                        android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:accessibilityLiveRegion="polite" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_nav"
                    android:layout_height="@dimen/icon_nav"
                    android:src="@drawable/ic_chevron_right"
                    android:importantForAccessibility="no"
                    app:tint="@color/textTertiary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Optimize Storage card — amber tint icon -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_optimize"
            style="@style/Widget.FileCleaner.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:minHeight="@dimen/card_min_height"
            android:foreground="@drawable/ripple_card"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusUp="@id/card_janitor"
            android:nextFocusDown="@id/card_arborescence"
            android:stateListAnimator="@animator/card_state_list_anim"
            android:contentDescription="@string/optimize_title">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_lg">

                <FrameLayout
                    android:layout_width="@dimen/icon_hub_circle"
                    android:layout_height="@dimen/icon_hub_circle"
                    android:background="@drawable/bg_hub_icon_circle"
                    android:backgroundTint="@color/tintOptimize"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="@dimen/hub_card_icon_inner"
                        android:layout_height="@dimen/hub_card_icon_inner"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_storage"
                        android:scaleType="centerInside"
                        android:importantForAccessibility="no"
                        app:tint="@color/accentOnTintAnalysis" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:layout_marginStart="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/optimize_title"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                        android:textColor="@color/textPrimary"
                        android:accessibilityHeading="true" />

                    <TextView
                        android:id="@+id/tv_optimize_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/optimize_desc"
                        android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:accessibilityLiveRegion="polite" />
                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_nav"
                    android:layout_height="@dimen/icon_nav"
                    android:src="@drawable/ic_chevron_right"
                    android:importantForAccessibility="no"
                    app:tint="@color/textTertiary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Advanced tools section label — visually distinct -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/raccoon_section_advanced"
            android:textAppearance="@style/TextAppearance.FileCleaner.SectionHeader"
            android:background="@drawable/bg_section_header"
            android:layout_marginBottom="@dimen/spacing_md"
            android:accessibilityHeading="true"
            android:importantForAccessibility="yes" />

        <!-- 2-column grid for advanced tools -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_md"
            android:baselineAligned="false">

            <!-- Tree View card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_arborescence"
                style="@style/Widget.FileCleaner.Card"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:foreground="@drawable/ripple_card"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusUp="@id/card_optimize"
                android:nextFocusRight="@id/card_dual_pane"
                android:nextFocusDown="@id/card_cloud"
                android:stateListAnimator="@animator/card_state_list_anim"
                android:contentDescription="@string/raccoon_action_arborescence">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="@dimen/icon_hub_circle"
                        android:layout_height="@dimen/icon_hub_circle"
                        android:background="@drawable/bg_hub_icon_circle"
                        android:backgroundTint="@color/tintTree"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="@dimen/hub_card_icon_inner"
                            android:layout_height="@dimen/hub_card_icon_inner"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_tree_structure"
                            android:scaleType="centerInside"
                            android:importantForAccessibility="no"
                            app:tint="@color/accentOnTintTree" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/raccoon_action_arborescence"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                        android:textColor="@color/textPrimary"
                        android:accessibilityHeading="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/raccoon_action_arborescence_desc"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:maxLines="2" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Dual Pane card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_dual_pane"
                style="@style/Widget.FileCleaner.Card"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:foreground="@drawable/ripple_card"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusUp="@id/card_optimize"
                android:nextFocusLeft="@id/card_arborescence"
                android:nextFocusDown="@id/card_antivirus"
                android:stateListAnimator="@animator/card_state_list_anim"
                android:contentDescription="@string/dual_pane_title">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="@dimen/icon_hub_circle"
                        android:layout_height="@dimen/icon_hub_circle"
                        android:background="@drawable/bg_hub_icon_circle"
                        android:backgroundTint="@color/tintDualPane"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="@dimen/hub_card_icon_inner"
                            android:layout_height="@dimen/hub_card_icon_inner"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_dual_pane"
                            android:scaleType="centerInside"
                            android:importantForAccessibility="no"
                            app:tint="@color/accentOnTintDualPane" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/dual_pane_title"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                        android:textColor="@color/textPrimary"
                        android:accessibilityHeading="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dual_pane_desc"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:maxLines="2" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Second row: Cloud + Antivirus -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_md"
            android:baselineAligned="false">

            <!-- Cloud / Network card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_cloud"
                style="@style/Widget.FileCleaner.Card"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:foreground="@drawable/ripple_card"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusUp="@id/card_arborescence"
                android:nextFocusRight="@id/card_antivirus"
                android:stateListAnimator="@animator/card_state_list_anim"
                android:contentDescription="@string/cloud_title">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="@dimen/icon_hub_circle"
                        android:layout_height="@dimen/icon_hub_circle"
                        android:background="@drawable/bg_hub_icon_circle"
                        android:backgroundTint="@color/tintCloud"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="@dimen/hub_card_icon_inner"
                            android:layout_height="@dimen/hub_card_icon_inner"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_cloud"
                            android:scaleType="centerInside"
                            android:importantForAccessibility="no"
                            app:tint="@color/catImageOnTintCloud" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/cloud_title"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                        android:textColor="@color/textPrimary"
                        android:accessibilityHeading="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cloud_desc"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:maxLines="2" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Antivirus card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_antivirus"
                style="@style/Widget.FileCleaner.Card"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:foreground="@drawable/ripple_card"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusUp="@id/card_dual_pane"
                android:nextFocusLeft="@id/card_cloud"
                android:stateListAnimator="@animator/card_state_list_anim"
                android:contentDescription="@string/av_title">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="@dimen/icon_hub_circle"
                        android:layout_height="@dimen/icon_hub_circle"
                        android:background="@drawable/bg_hub_icon_circle"
                        android:backgroundTint="@color/tintAntivirus"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="@dimen/hub_card_icon_inner"
                            android:layout_height="@dimen/hub_card_icon_inner"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_shield"
                            android:scaleType="centerInside"
                            android:importantForAccessibility="no"
                            app:tint="@color/colorPrimary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/av_title"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                        android:textColor="@color/textPrimary"
                        android:accessibilityHeading="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/av_desc"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:maxLines="2" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Third row: Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_md"
            android:baselineAligned="false">

            <!-- Settings card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_settings"
                style="@style/Widget.FileCleaner.Card"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:foreground="@drawable/ripple_card"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:nextFocusUp="@id/card_cloud"
                android:stateListAnimator="@animator/card_state_list_anim"
                android:contentDescription="@string/settings">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <FrameLayout
                        android:layout_width="@dimen/icon_hub_circle"
                        android:layout_height="@dimen/icon_hub_circle"
                        android:background="@drawable/bg_hub_icon_circle"
                        android:backgroundTint="@color/tintSettings"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="@dimen/hub_card_icon_inner"
                            android:layout_height="@dimen/hub_card_icon_inner"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_settings"
                            android:scaleType="centerInside"
                            android:importantForAccessibility="no"
                            app:tint="@color/accentOnTintSettings" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/settings"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                        android:textColor="@color/textPrimary"
                        android:accessibilityHeading="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_desc"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:maxLines="2" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Empty spacer to maintain grid alignment -->
            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/spacing_sm" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
