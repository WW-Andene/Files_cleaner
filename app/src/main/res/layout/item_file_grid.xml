<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_xs"
    app:cardCornerRadius="@dimen/radius_card"
    app:cardElevation="@dimen/elevation_subtle"
    app:cardBackgroundColor="@color/surfaceColor"
    app:strokeWidth="@dimen/stroke_default"
    app:strokeColor="@color/borderSubtle"
    app:rippleColor="@color/colorPrimaryContainer"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Color accent stripe (4dp top edge indicator for grid mode) -->
        <View
            android:id="@+id/view_accent_stripe"
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_xs"
            android:importantForAccessibility="no"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="@dimen/elevation_none"
            app:strokeWidth="@dimen/stroke_none"
            app:cardBackgroundColor="@color/surfaceDim">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/iv_file_icon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/grid_thumbnail_min_height"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:importantForAccessibility="no"
                    android:contentDescription="@string/a11y_file_type_icon" />

                <CheckBox
                    android:id="@+id/cb_select"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="@dimen/spacing_xs"
                    android:minWidth="@dimen/touch_target_min"
                    android:minHeight="@dimen/touch_target_min"
                    android:clickable="false"
                    android:buttonTint="@color/colorPrimary"
                    android:contentDescription="@string/a11y_select_checkbox"
                    android:visibility="gone" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_md">

            <TextView
                android:id="@+id/tv_file_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.BodySmallMedium"
                android:textColor="@color/textPrimary"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_file_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                android:textColor="@color/textTertiary"
                android:maxLines="1"
                android:layout_marginTop="@dimen/spacing_xs" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
