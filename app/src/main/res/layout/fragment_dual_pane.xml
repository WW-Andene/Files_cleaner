<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surfaceBase">

    <!-- Top toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_sm"
        android:paddingVertical="@dimen/spacing_xs">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/icon_button"
            android:layout_height="@dimen/icon_button"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:scaleType="centerInside"
            app:tint="@color/textPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/dual_pane_title"
            android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
            android:textColor="@color/textPrimary"
            android:layout_marginStart="@dimen/spacing_xs" />

        <!-- Swap panes button -->
        <ImageButton
            android:id="@+id/btn_swap_panes"
            android:layout_width="@dimen/icon_button"
            android:layout_height="@dimen/icon_button"
            android:src="@drawable/ic_swap_horiz"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/dual_pane_swap"
            android:scaleType="centerInside"
            app:tint="@color/textSecondary" />
    </LinearLayout>

    <!-- Dual panes side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left pane -->
        <LinearLayout
            android:id="@+id/pane_left"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/surfaceColor"
            android:layout_marginEnd="1dp">

            <!-- Left pane content mode selector -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mode_left"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@color/surfaceDim"
                android:text="@string/dual_pane_tab_browse"
                android:textAllCaps="false"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/text_body_small"
                android:gravity="start|center_vertical"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="@dimen/spacing_sm"
                app:icon="@drawable/ic_arrow_down"
                app:iconSize="14dp"
                app:iconGravity="end"
                app:iconTint="@color/textSecondary" />

            <!-- Left pane path bar -->
            <LinearLayout
                android:id="@+id/path_bar_left"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="@dimen/spacing_xs"
                android:background="@color/surfaceDim">

                <ImageButton
                    android:id="@+id/btn_up_left"
                    android:layout_width="@dimen/icon_button"
                    android:layout_height="@dimen/icon_button"
                    android:src="@drawable/ic_arrow_up"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/dual_pane_go_up"
                    android:scaleType="centerInside"
                    android:padding="@dimen/spacing_chip"
                    app:tint="@color/textSecondary" />

                <TextView
                    android:id="@+id/tv_path_left"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="/"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                    android:textColor="@color/colorPrimary"
                    android:singleLine="true"
                    android:ellipsize="start"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:background="?attr/selectableItemBackground"
                    android:padding="2dp" />

                <ImageButton
                    android:id="@+id/btn_pick_dir_left"
                    android:layout_width="@dimen/icon_button"
                    android:layout_height="@dimen/icon_button"
                    android:src="@drawable/ic_folder"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/dual_pane_pick_directory"
                    android:scaleType="centerInside"
                    android:padding="@dimen/spacing_chip"
                    app:tint="@color/textSecondary" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_left"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/spacing_sm" />

            <!-- Left pane file count -->
            <TextView
                android:id="@+id/tv_count_left"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                android:textColor="@color/textTertiary"
                android:gravity="center"
                android:paddingVertical="2dp"
                android:background="@color/surfaceDim" />
        </LinearLayout>

        <!-- Divider handle -->
        <FrameLayout
            android:id="@+id/divider_handle"
            android:layout_width="@dimen/spacing_md"
            android:layout_height="match_parent"
            android:background="@color/surfaceDim"
            android:contentDescription="@string/dual_pane_divider_handle">

            <!-- Visual grip dots -->
            <View
                android:layout_width="4dp"
                android:layout_height="@dimen/icon_file_list_default"
                android:layout_gravity="center"
                android:background="@color/borderDefault" />
        </FrameLayout>

        <!-- Right pane -->
        <LinearLayout
            android:id="@+id/pane_right"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/surfaceColor"
            android:layout_marginStart="1dp">

            <!-- Right pane content mode selector -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mode_right"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@color/surfaceDim"
                android:text="@string/dual_pane_tab_browse"
                android:textAllCaps="false"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/text_body_small"
                android:gravity="start|center_vertical"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="@dimen/spacing_sm"
                app:icon="@drawable/ic_arrow_down"
                app:iconSize="14dp"
                app:iconGravity="end"
                app:iconTint="@color/textSecondary" />

            <!-- Right pane path bar -->
            <LinearLayout
                android:id="@+id/path_bar_right"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_xs"
                android:paddingVertical="@dimen/spacing_xs"
                android:background="@color/surfaceDim">

                <ImageButton
                    android:id="@+id/btn_up_right"
                    android:layout_width="@dimen/icon_button"
                    android:layout_height="@dimen/icon_button"
                    android:src="@drawable/ic_arrow_up"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/dual_pane_go_up"
                    android:scaleType="centerInside"
                    android:padding="@dimen/spacing_chip"
                    app:tint="@color/textSecondary" />

                <TextView
                    android:id="@+id/tv_path_right"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="/"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                    android:textColor="@color/colorPrimary"
                    android:singleLine="true"
                    android:ellipsize="start"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:background="?attr/selectableItemBackground"
                    android:padding="2dp" />

                <ImageButton
                    android:id="@+id/btn_pick_dir_right"
                    android:layout_width="@dimen/icon_button"
                    android:layout_height="@dimen/icon_button"
                    android:src="@drawable/ic_folder"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/dual_pane_pick_directory"
                    android:scaleType="centerInside"
                    android:padding="@dimen/spacing_chip"
                    app:tint="@color/textSecondary" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_right"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/spacing_sm" />

            <!-- Right pane file count -->
            <TextView
                android:id="@+id/tv_count_right"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                android:textColor="@color/textTertiary"
                android:gravity="center"
                android:paddingVertical="2dp"
                android:background="@color/surfaceDim" />
        </LinearLayout>
    </LinearLayout>

    <!-- Floating selection action bar (hidden by default) -->
    <LinearLayout
        android:id="@+id/selection_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surfaceColor"
        android:elevation="@dimen/elevation_nav"
        android:visibility="gone">

        <!-- Selection info row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_xs">

            <TextView
                android:id="@+id/tv_selection_count"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_select_all"
                android:layout_width="@dimen/icon_button"
                android:layout_height="@dimen/icon_button"
                android:src="@drawable/ic_select_all"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/dual_pane_select_all"
                android:scaleType="centerInside"
                android:padding="@dimen/spacing_sm"
                app:tint="@color/textSecondary" />

            <ImageButton
                android:id="@+id/btn_clear_selection"
                android:layout_width="@dimen/icon_button"
                android:layout_height="@dimen/icon_button"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/dual_pane_deselect_all"
                android:scaleType="centerInside"
                android:padding="@dimen/spacing_sm"
                app:tint="@color/textSecondary" />
        </LinearLayout>

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_sm">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_copy_to_other"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/button_height_sm"
                android:text="@string/dual_pane_copy"
                android:textAllCaps="false"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:icon="@drawable/ic_copy"
                app:iconSize="@dimen/icon_small"
                app:cornerRadius="@dimen/radius_pill"
                app:strokeColor="@color/borderDefault" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_move_to_other"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/button_height_sm"
                android:text="@string/dual_pane_move"
                android:textAllCaps="false"
                android:layout_marginHorizontal="@dimen/spacing_xs"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:icon="@drawable/ic_move"
                app:iconSize="@dimen/icon_small"
                app:cornerRadius="@dimen/radius_pill"
                app:strokeColor="@color/borderDefault" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_selected"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/button_height_sm"
                android:text="@string/delete"
                android:textAllCaps="false"
                android:layout_marginStart="@dimen/spacing_xs"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:icon="@drawable/ic_delete"
                app:iconSize="@dimen/icon_small"
                app:cornerRadius="@dimen/radius_pill"
                app:strokeColor="@color/colorError"
                android:textColor="@color/colorError"
                app:iconTint="@color/colorError" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
