<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surfaceBase">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="@dimen/spacing_sm">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/icon_button"
            android:layout_height="@dimen/icon_button"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:scaleType="centerInside"
            app:tint="@color/textPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/dual_pane_title"
            android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
            android:textColor="@color/textPrimary"
            android:layout_marginStart="@dimen/spacing_sm" />
    </LinearLayout>

    <!-- Dual panes side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left pane -->
        <LinearLayout
            android:id="@+id/pane_left"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/surfaceColor"
            android:layout_marginEnd="1dp">

            <!-- Left pane path bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs"
                android:background="@color/surfaceDim">

                <ImageButton
                    android:id="@+id/btn_up_left"
                    android:layout_width="@dimen/icon_button"
                    android:layout_height="@dimen/icon_button"
                    android:src="@drawable/ic_folder"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/dual_pane_go_up"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    app:tint="@color/textSecondary" />

                <TextView
                    android:id="@+id/tv_path_left"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="/"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                    android:textColor="@color/textSecondary"
                    android:singleLine="true"
                    android:ellipsize="start"
                    android:layout_marginStart="@dimen/spacing_xs" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_left"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/spacing_sm" />

            <!-- Left pane file count -->
            <TextView
                android:id="@+id/tv_count_left"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                android:textColor="@color/textTertiary"
                android:gravity="center"
                android:paddingVertical="@dimen/spacing_xs"
                android:background="@color/surfaceDim" />
        </LinearLayout>

        <!-- Splitter / divider -->
        <View
            android:id="@+id/splitter"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/borderDefault" />

        <!-- Right pane -->
        <LinearLayout
            android:id="@+id/pane_right"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/surfaceColor"
            android:layout_marginStart="1dp">

            <!-- Right pane path bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs"
                android:background="@color/surfaceDim">

                <ImageButton
                    android:id="@+id/btn_up_right"
                    android:layout_width="@dimen/icon_button"
                    android:layout_height="@dimen/icon_button"
                    android:src="@drawable/ic_folder"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/dual_pane_go_up"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    app:tint="@color/textSecondary" />

                <TextView
                    android:id="@+id/tv_path_right"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="/"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                    android:textColor="@color/textSecondary"
                    android:singleLine="true"
                    android:ellipsize="start"
                    android:layout_marginStart="@dimen/spacing_xs" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_right"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/spacing_sm" />

            <!-- Right pane file count -->
            <TextView
                android:id="@+id/tv_count_right"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                android:textColor="@color/textTertiary"
                android:gravity="center"
                android:paddingVertical="@dimen/spacing_xs"
                android:background="@color/surfaceDim" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="@dimen/spacing_sm"
        android:background="@color/surfaceDim">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_to_other"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="@dimen/button_height_sm"
            android:text="@string/dual_pane_copy"
            android:textAllCaps="false"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="@dimen/radius_pill"
            app:strokeColor="@color/borderDefault" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_move_to_other"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="@dimen/button_height_sm"
            android:text="@string/dual_pane_move"
            android:textAllCaps="false"
            android:layout_marginHorizontal="@dimen/spacing_xs"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="@dimen/radius_pill"
            app:strokeColor="@color/borderDefault" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete_selected"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="@dimen/button_height_sm"
            android:text="@string/delete"
            android:textAllCaps="false"
            android:layout_marginStart="@dimen/spacing_xs"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="@dimen/radius_pill"
            app:strokeColor="@color/colorError"
            android:textColor="@color/colorError" />
    </LinearLayout>
</LinearLayout>
