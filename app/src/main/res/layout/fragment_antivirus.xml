<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surfaceBase">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="@dimen/spacing_sm">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/icon_button"
            android:layout_height="@dimen/icon_button"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:scaleType="centerInside"
            app:tint="@color/textPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/av_title"
            android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
            android:textColor="@color/textPrimary"
            android:layout_marginStart="@dimen/spacing_sm" />

        <ImageButton
            android:id="@+id/btn_history"
            android:layout_width="@dimen/icon_button"
            android:layout_height="@dimen/icon_button"
            android:src="@drawable/ic_scan"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/av_history"
            android:scaleType="centerInside"
            app:tint="@color/textSecondary" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Shield icon + status area -->
            <LinearLayout
                android:id="@+id/shield_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="@dimen/spacing_lg">

                <FrameLayout
                    android:layout_width="@dimen/icon_empty_state"
                    android:layout_height="@dimen/icon_empty_state"
                    android:background="@drawable/bg_hub_icon_circle"
                    android:backgroundTint="@color/tintAntivirus"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/iv_shield"
                        android:layout_width="@dimen/icon_hub_circle"
                        android:layout_height="@dimen/icon_hub_circle"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_shield"
                        app:tint="@color/colorPrimary"
                        android:contentDescription="@string/av_title" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/av_ready"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                    android:textColor="@color/textPrimary"
                    android:gravity="center"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:paddingHorizontal="@dimen/spacing_lg" />

                <TextView
                    android:id="@+id/tv_last_scan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                    android:textColor="@color/textTertiary"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Phase progress area -->
            <LinearLayout
                android:id="@+id/progress_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:visibility="gone">

                <ProgressBar
                    android:id="@+id/progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progressTint="@color/colorPrimary" />

                <TextView
                    android:id="@+id/tv_progress_pct"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Numeric"
                    android:textColor="@color/colorPrimary"
                    android:gravity="end"
                    android:layout_marginTop="@dimen/spacing_micro"
                    android:text="0%" />

                <TextView
                    android:id="@+id/tv_phase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                    android:textColor="@color/textSecondary"
                    android:layout_marginTop="@dimen/spacing_xs" />

                <TextView
                    android:id="@+id/tv_phase_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                    android:textColor="@color/textTertiary"
                    android:layout_marginTop="@dimen/spacing_micro" />
            </LinearLayout>

            <!-- Start scan / scan again button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scan"
                style="@style/Widget.FileCleaner.Button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginHorizontal="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/av_start_scan"
                android:textAllCaps="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_shield"
                app:iconGravity="textStart"
                app:cornerRadius="@dimen/radius_pill" />

            <!-- Summary cards row -->
            <LinearLayout
                android:id="@+id/summary_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_md"
                android:visibility="gone">

                <!-- Critical card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="@dimen/elevation_none"
                    app:cardBackgroundColor="@color/colorErrorLight"
                    app:strokeWidth="@dimen/stroke_default"
                    app:strokeColor="@color/colorError">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_sm">

                        <TextView
                            android:id="@+id/tv_critical_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textAppearance="@style/TextAppearance.FileCleaner.NumericTitle"
                            android:textColor="@color/colorError" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/av_critical"
                            android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                            android:textColor="@color/colorError" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- High card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/spacing_xs"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="@dimen/elevation_none"
                    app:cardBackgroundColor="@color/surfaceColor"
                    app:strokeWidth="@dimen/stroke_default"
                    app:strokeColor="@color/borderSubtle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_sm">

                        <TextView
                            android:id="@+id/tv_high_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textAppearance="@style/TextAppearance.FileCleaner.NumericTitle"
                            android:textColor="@color/colorAccent" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/av_high"
                            android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                            android:textColor="@color/textTertiary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Medium card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/spacing_xs"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="@dimen/elevation_none"
                    app:cardBackgroundColor="@color/surfaceColor"
                    app:strokeWidth="@dimen/stroke_default"
                    app:strokeColor="@color/borderSubtle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_sm">

                        <TextView
                            android:id="@+id/tv_medium_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textAppearance="@style/TextAppearance.FileCleaner.NumericTitle"
                            android:textColor="@color/colorWarning" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/av_medium"
                            android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                            android:textColor="@color/textTertiary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Clean card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="@dimen/elevation_none"
                    app:cardBackgroundColor="@color/surfaceColor"
                    app:strokeWidth="@dimen/stroke_default"
                    app:strokeColor="@color/borderSubtle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_sm">

                        <TextView
                            android:id="@+id/tv_clean_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textAppearance="@style/TextAppearance.FileCleaner.NumericTitle"
                            android:textColor="@color/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/av_clean"
                            android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                            android:textColor="@color/textTertiary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Fix All button (shown when actionable threats exist) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_fix_all"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_sm"
                android:layout_marginHorizontal="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/av_fix_all"
                android:textAllCaps="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone"
                style="@style/Widget.FileCleaner.Button.Outlined"
                app:cornerRadius="@dimen/radius_pill"
                app:strokeColor="@color/colorError"
                android:textColor="@color/colorError" />

            <!-- Filter chips -->
            <HorizontalScrollView
                android:id="@+id/filter_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_sm"
                android:visibility="gone">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/av_filter_all"
                        style="@style/Widget.FileCleaner.Chip.Choice"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_critical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/av_critical"
                        style="@style/Widget.FileCleaner.Chip.Choice" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_high"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/av_high"
                        style="@style/Widget.FileCleaner.Chip.Choice" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/av_medium"
                        style="@style/Widget.FileCleaner.Chip.Choice" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_low_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/av_filter_low_info"
                        style="@style/Widget.FileCleaner.Chip.Choice" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- Results list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:layoutAnimation="@anim/layout_item_stagger"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_above_nav"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
