<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfaceBase">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surfaceBase"
        app:elevation="@dimen/elevation_none">

        <!-- Scan status bar — soft container style; hidden in idle, shown during scan/result -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/scan_bar_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginBottom="@dimen/spacing_xs"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="@dimen/elevation_none"
            app:cardBackgroundColor="@color/scanBarBackground"
            app:strokeWidth="@dimen/stroke_none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_md"
                android:paddingBottom="@dimen/spacing_sm">

                <!-- Top row: icon + status text + cancel button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_inline"
                        android:layout_height="@dimen/icon_inline"
                        android:src="@drawable/ic_scan"
                        android:contentDescription="@string/a11y_scan_icon"
                        app:tint="@color/colorPrimary" />

                    <TextView
                        android:id="@+id/tv_scan_status"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text=""
                        android:textAppearance="@style/TextAppearance.FileCleaner.BodyMedium"
                        android:textColor="@color/scanBarText"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:accessibilityLiveRegion="polite" />

                    <!-- Percentage text shown during scanning -->
                    <TextView
                        android:id="@+id/tv_scan_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:textAppearance="@style/TextAppearance.FileCleaner.NumericMedium"
                        android:textColor="@color/colorPrimary"
                        android:visibility="gone"
                        android:accessibilityLiveRegion="polite" />

                    <ImageButton
                        android:id="@+id/btn_cancel_scan"
                        android:layout_width="@dimen/icon_button"
                        android:layout_height="@dimen/icon_button"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:padding="@dimen/spacing_md"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/scan_cancel"
                        android:visibility="gone"
                        app:tint="@color/textSecondary" />
                </LinearLayout>

                <!-- Material LinearProgressIndicator: shown during scanning -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/scan_progress_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:visibility="gone"
                    android:contentDescription="@string/a11y_scan_phase_progress"
                    android:accessibilityLiveRegion="polite"
                    app:indicatorColor="@color/colorPrimary"
                    app:trackColor="@color/colorPrimaryContainer"
                    app:trackCornerRadius="@dimen/track_corner_radius"
                    app:trackThickness="@dimen/spacing_xs" />

                <!-- Phase step indicators: dot row showing scan stages -->
                <LinearLayout
                    android:id="@+id/scan_phase_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/spacing_chip"
                    android:visibility="gone"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_phase_label"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                        android:textColor="@color/textTertiary"
                        android:accessibilityLiveRegion="polite" />

                    <TextView
                        android:id="@+id/tv_phase_step"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                        android:textColor="@color/textTertiary"
                        android:accessibilityLiveRegion="polite" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Fragment container — bottom padding managed dynamically based on bottom nav visibility -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="@dimen/bottom_nav_height"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <!-- Bottom nav with subtle top divider -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/divider_width"
            android:background="@color/bottomNavDivider"
            android:importantForAccessibility="no" />

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bottomNavBackground"
            app:menu="@menu/bottom_nav_menu"
            app:labelVisibilityMode="labeled"
            app:itemIconTint="@color/bottom_nav_color"
            app:itemTextColor="@color/bottom_nav_color"
            app:elevation="@dimen/elevation_none" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
