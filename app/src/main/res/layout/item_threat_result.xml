<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/radius_card"
    app:cardElevation="@dimen/elevation_subtle"
    app:cardBackgroundColor="@color/surfaceColor"
    app:strokeWidth="@dimen/stroke_default"
    app:strokeColor="@color/borderSubtle"
    app:rippleColor="@color/colorPrimaryContainer"
    android:clickable="true"
    android:focusable="true"
    android:minHeight="@dimen/touch_target_min">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingVertical="@dimen/spacing_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="@dimen/touch_target_min">

            <!-- Severity indicator -->
            <View
                android:id="@+id/severity_dot"
                android:layout_width="@dimen/spacing_md"
                android:layout_height="@dimen/spacing_md"
                android:background="@drawable/bg_icon_circle"
                android:importantForAccessibility="no"
                android:contentDescription="@string/a11y_severity_indicator" />

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                android:textColor="@color/textPrimary"
                android:layout_marginStart="@dimen/spacing_md" />

            <TextView
                android:id="@+id/tv_severity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.Label"
                android:importantForAccessibility="yes"
                android:layout_marginStart="@dimen/spacing_sm" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="@dimen/spacing_xs"
            android:lineSpacingExtra="@dimen/spacing_micro" />

        <TextView
            android:id="@+id/tv_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
            android:textColor="@color/textTertiary"
            android:layout_marginTop="@dimen/spacing_xs" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:minHeight="@dimen/touch_target_min"
            android:textAllCaps="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:visibility="gone"
            style="@style/Widget.FileCleaner.Button.Outlined"
            app:cornerRadius="@dimen/radius_pill"
            app:strokeColor="@color/colorError"
            android:textColor="@color/colorError"
            android:contentDescription="@string/a11y_fix_threat" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
