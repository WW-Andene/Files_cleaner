<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/radius_card"
    app:cardElevation="@dimen/elevation_none"
    app:cardBackgroundColor="@color/surfaceColor"
    app:strokeWidth="@dimen/stroke_default"
    app:strokeColor="@color/borderSubtle">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Severity indicator -->
            <View
                android:id="@+id/severity_dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_icon_circle" />

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                android:textColor="@color/textPrimary"
                android:layout_marginStart="@dimen/spacing_sm" />

            <TextView
                android:id="@+id/tv_severity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="@dimen/spacing_xs" />

        <TextView
            android:id="@+id/tv_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
            android:textColor="@color/textTertiary"
            android:layout_marginTop="@dimen/spacing_xs" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:minHeight="48dp"
            android:textAllCaps="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="@dimen/radius_pill"
            app:strokeColor="@color/colorError"
            android:textColor="@color/colorError" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
