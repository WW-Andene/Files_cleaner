<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surfaceBase">

    <!-- Header card (title + subtitle only — selection buttons moved to action bar) -->
    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.FileCleaner.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_sm"
        app:cardCornerRadius="@dimen/radius_header"
        app:cardElevation="@dimen/elevation_none"
        app:cardBackgroundColor="@color/colorPrimaryContainer"
        app:strokeWidth="@dimen/stroke_none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_md">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.Title"
                android:textColor="@color/colorOnPrimaryContainer"
                android:maxLines="2"
                android:ellipsize="end"
                android:accessibilityHeading="true"
                tools:text="Title" />

            <TextView
                android:id="@+id/tv_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                android:textColor="@color/colorOnPrimaryContainer"
                android:alpha="@dimen/alpha_raccoon_logo"
                android:maxLines="2"
                android:ellipsize="end"
                android:accessibilityLiveRegion="polite"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/scan_to_see_results" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Color legend strip (populated programmatically per screen) -->
    <include
        layout="@layout/view_color_legend"
        android:id="@+id/legend_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Search bar -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_md"
        android:contentDescription="@string/a11y_search_files"
        app:startIconDrawable="@drawable/ic_search"
        app:endIconMode="clear_text"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="@dimen/radius_input"
        app:boxCornerRadiusTopEnd="@dimen/radius_input"
        app:boxCornerRadiusBottomStart="@dimen/radius_input"
        app:boxCornerRadiusBottomEnd="@dimen/radius_input"
        app:boxStrokeColor="@color/borderDefault"
        app:hintTextColor="@color/colorPrimary"
        app:startIconTint="@color/textTertiary"
        style="@style/Widget.FileCleaner.TextInput">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/search_files_hint"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionSearch"
            android:textAppearance="@style/TextAppearance.FileCleaner.Body"
            android:lineSpacingMultiplier="1.0" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Collapsible filter toggle bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_sm">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_toggle_filters"
            style="@style/Widget.FileCleaner.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:text="@string/filter_options"
            android:textAllCaps="false"
            android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
            android:textColor="@color/textSecondary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="@string/a11y_filter_options"
            app:icon="@drawable/ic_arrow_down"
            app:iconSize="@dimen/icon_small"
            app:iconGravity="end"
            app:iconTint="@color/textSecondary" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:importantForAccessibility="no" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_view_mode"
            style="@style/Widget.FileCleaner.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:text="@string/display_options"
            android:textAllCaps="false"
            android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
            android:textColor="@color/textSecondary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="@string/a11y_display_options"
            app:icon="@drawable/ic_arrow_down"
            app:iconSize="@dimen/icon_small"
            app:iconGravity="end"
            app:iconTint="@color/textSecondary" />
    </LinearLayout>

    <!-- Expandable filter panel -->
    <LinearLayout
        android:id="@+id/filter_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sort_by_label"
            android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
            android:textColor="@color/textTertiary"
            android:layout_marginTop="@dimen/spacing_xs"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <Spinner
            android:id="@+id/spinner_sort"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:minHeight="@dimen/touch_target_min"
            android:background="@drawable/bg_spinner"
            android:popupBackground="@drawable/bg_spinner_dropdown"
            android:paddingHorizontal="@dimen/spacing_md"
            android:contentDescription="@string/a11y_sort_order" />

        <!-- Size selector -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/size_label"
            android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
            android:textColor="@color/textTertiary"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginBottom="@dimen/spacing_xs" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_grid_columns"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="@dimen/spacing_chip" />
    </LinearLayout>

    <!-- F5: Scan progress indicator -->
    <ProgressBar
        android:id="@+id/progress_scan"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_xs"
        android:indeterminate="true"
        android:indeterminateTint="@color/colorPrimary"
        android:accessibilityLiveRegion="polite"
        android:contentDescription="@string/a11y_scan_progress"
        android:visibility="gone" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="@dimen/spacing_3xl"
        android:paddingTop="@dimen/spacing_5xl"
        android:paddingBottom="@dimen/spacing_4xl"
        android:accessibilityLiveRegion="polite"
        android:contentDescription="@string/a11y_empty_state"
        android:visibility="gone">

        <ImageView
            android:layout_width="@dimen/icon_empty_state"
            android:layout_height="@dimen/icon_empty_state"
            android:src="@drawable/ic_raccoon_logo"
            android:alpha="@dimen/alpha_raccoon_logo"
            android:importantForAccessibility="no"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tv_empty_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:text="@string/nothing_found"
            android:textAppearance="@style/TextAppearance.FileCleaner.Title"
            android:textColor="@color/textPrimary"
            android:gravity="center"
            android:maxWidth="@dimen/content_max_width_narrow"
            android:lineSpacingExtra="@dimen/spacing_xs" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_scan_now"
            style="@style/Widget.FileCleaner.Button"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/scan_storage"
            android:textAllCaps="false"
            android:visibility="gone"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="@dimen/radius_pill" />
    </LinearLayout>

    <!-- File list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_fab_clearance"
        android:layoutAnimation="@anim/layout_item_stagger" />

    <!-- Selection scope buttons (visible only when items are selected) -->
    <HorizontalScrollView
        android:id="@+id/selection_buttons_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_sm"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_select_all"
                style="@style/Widget.FileCleaner.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:text="@string/select_all"
                android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="@dimen/radius_pill" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_deselect_all"
                style="@style/Widget.FileCleaner.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:text="@string/deselect_all"
                android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="@dimen/radius_pill" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_batch_rename"
                style="@style/Widget.FileCleaner.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:text="@string/batch_rename"
                android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                android:layout_marginStart="@dimen/spacing_sm"
                android:visibility="gone"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="@dimen/radius_pill" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_batch_compress"
                style="@style/Widget.FileCleaner.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:text="@string/ctx_compress"
                android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                android:layout_marginStart="@dimen/spacing_sm"
                android:visibility="gone"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="@dimen/radius_pill" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Action button — not full-width for better visual proportion (§DBI3 #10) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_action"
        style="@style/Widget.FileCleaner.Button.Destructive"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/button_height"
        android:layout_gravity="center_horizontal"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_bottom_inset"
        android:minWidth="@dimen/button_min_width"
        android:paddingHorizontal="@dimen/spacing_3xl"
        android:text="@string/delete_selected"
        android:enabled="false"
        android:focusable="true"
        android:textAppearance="@style/TextAppearance.FileCleaner.BodyMedium" />

</LinearLayout>
