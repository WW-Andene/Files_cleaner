<?xml version="1.0" encoding="utf-8"?>
<!--
    §DM2: All fragment destinations declare consistent enter/exit animations
    from the motion vocabulary so that every navigation — even those triggered
    without explicit NavOptions — gets the standard page transition.
-->
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/raccoonManagerFragment">

    <!-- §DM2: Global navigation actions — ensures every navigation gets
         consistent page-transition animations from the motion vocabulary,
         even when triggered without explicit NavOptions. -->
    <action
        android:id="@+id/action_global_analysisFragment"
        app:destination="@id/analysisFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_browseFragment"
        app:destination="@id/browseFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_duplicatesFragment"
        app:destination="@id/duplicatesFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_largeFilesFragment"
        app:destination="@id/largeFilesFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_junkFragment"
        app:destination="@id/junkFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_raccoonManagerFragment"
        app:destination="@id/raccoonManagerFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_arborescenceFragment"
        app:destination="@id/arborescenceFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_settingsFragment"
        app:destination="@id/settingsFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_optimizeFragment"
        app:destination="@id/optimizeFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_dualPaneFragment"
        app:destination="@id/dualPaneFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_cloudBrowserFragment"
        app:destination="@id/cloudBrowserFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_antivirusFragment"
        app:destination="@id/antivirusFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_fileViewerFragment"
        app:destination="@id/fileViewerFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <action
        android:id="@+id/action_global_dashboardFragment"
        app:destination="@id/dashboardFragment"
        app:enterAnim="@anim/nav_enter"
        app:exitAnim="@anim/nav_exit"
        app:popEnterAnim="@anim/nav_pop_enter"
        app:popExitAnim="@anim/nav_pop_exit" />

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.filecleaner.app.ui.dashboard.StorageDashboardFragment"
        android:label="@string/dashboard_title" />

    <fragment
        android:id="@+id/analysisFragment"
        android:name="com.filecleaner.app.ui.analysis.AnalysisFragment"
        android:label="@string/nav_analysis" />

    <fragment
        android:id="@+id/browseFragment"
        android:name="com.filecleaner.app.ui.browse.BrowseFragment"
        android:label="@string/nav_browse" />

    <fragment
        android:id="@+id/duplicatesFragment"
        android:name="com.filecleaner.app.ui.duplicates.DuplicatesFragment"
        android:label="@string/nav_duplicates" />

    <fragment
        android:id="@+id/largeFilesFragment"
        android:name="com.filecleaner.app.ui.large.LargeFilesFragment"
        android:label="@string/nav_large" />

    <fragment
        android:id="@+id/junkFragment"
        android:name="com.filecleaner.app.ui.junk.JunkFragment"
        android:label="@string/nav_junk" />

    <fragment
        android:id="@+id/raccoonManagerFragment"
        android:name="com.filecleaner.app.ui.raccoon.RaccoonManagerFragment"
        android:label="@string/nav_raccoon" />

    <fragment
        android:id="@+id/arborescenceFragment"
        android:name="com.filecleaner.app.ui.arborescence.ArborescenceFragment"
        android:label="@string/tree_view" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.filecleaner.app.ui.settings.SettingsFragment"
        android:label="@string/settings" />

    <fragment
        android:id="@+id/optimizeFragment"
        android:name="com.filecleaner.app.ui.optimize.OptimizeFragment"
        android:label="@string/optimize_title" />

    <fragment
        android:id="@+id/dualPaneFragment"
        android:name="com.filecleaner.app.ui.dualpane.DualPaneFragment"
        android:label="@string/dual_pane_title" />

    <fragment
        android:id="@+id/cloudBrowserFragment"
        android:name="com.filecleaner.app.ui.cloud.CloudBrowserFragment"
        android:label="@string/cloud_title" />

    <fragment
        android:id="@+id/antivirusFragment"
        android:name="com.filecleaner.app.ui.security.AntivirusFragment"
        android:label="@string/av_title" />

    <fragment
        android:id="@+id/fileViewerFragment"
        android:name="com.filecleaner.app.ui.viewer.FileViewerFragment"
        android:label="@string/viewer_title">
        <argument
            android:name="file_path"
            app:argType="string" />
    </fragment>

</navigation>
