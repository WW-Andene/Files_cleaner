<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ═══════════════════════════════════════════════════════════════
         Raccoon File Manager — Dark Mode Color System
         Brand: Forest green (#5ECE9E lifted) + Warm amber (#F2A84E lifted)
         Philosophy: Chromatic near-blacks with green tint, never neutral
         Perceptual model: OKLCH for lightness steps, warm hue bias
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Primary: Lighter green for dark mode legibility ── -->
    <color name="colorPrimary">#5ECE9E</color>
    <color name="colorPrimaryDark">#247A58</color>
    <color name="colorPrimaryLight">#7BDBB4</color>
    <color name="colorPrimaryContainer">#183828</color>
    <color name="colorOnPrimaryContainer">#B0E8CE</color>
    <color name="colorOnPrimary">#0C1A14</color>

    <!-- ── Accent: Warm amber — lifted for dark surfaces ── -->
    <color name="colorAccent">#F2A84E</color>
    <color name="colorAccentLight">#3D2E1A</color>
    <color name="colorOnAccent">#1C1208</color>
    <color name="colorAccentContainer">#3D2E1A</color>
    <color name="colorOnAccentContainer">#F2D4A0</color>

    <!-- ── Semantic — warm-shifted for character consistency ── -->
    <color name="colorError">#EF6B6B</color>
    <color name="colorErrorLight">#3D1F1A</color>
    <color name="colorOnError">#1C0A08</color>
    <color name="colorSuccess">#5ECE78</color>
    <color name="colorSuccessLight">#1A3D1F</color>
    <color name="colorOnSuccess">#0C1A0F</color>
    <color name="colorWarning">#FFD06A</color>
    <color name="colorWarningLight">#3D331A</color>
    <color name="colorOnWarning">#1C1608</color>

    <!-- ── Surface elevation ladder (chromatic near-blacks, §DC3) ──
         ~3-4% OKLCH lightness steps, green-tinted:
         surfaceDim(L5) → surfaceBase(L8) → surfaceColor(L12) → surfaceElevated(L16) -->
    <color name="surfaceDim">#080C0A</color>
    <color name="surfaceBase">#0C110F</color>
    <color name="surfaceColor">#141A17</color>
    <color name="surfaceElevated">#1C2420</color>

    <!-- ── Material 3 surface container hierarchy (§DC3) ──
         Maps to M3 surface container roles for layered UI
         Lowest(L7) → Low(L10) → Mid(L13) → High(L16) → Highest(L19) -->
    <color name="surfaceContainerLowest">#0A0E0C</color>
    <color name="surfaceContainerLow">#111614</color>
    <color name="surfaceContainer">#171D1A</color>
    <color name="surfaceContainerHigh">#1E2522</color>
    <color name="surfaceContainerHighest">#252D29</color>

    <!-- ── Text (chromatic green-gray, not pure gray, §DC5) ── -->
    <color name="textPrimary">#ECE9E4</color>
    <color name="textSecondary">#A2A8A5</color>
    <color name="textTertiary">#7E8682</color>
    <color name="textOnPrimary">#0C110F</color>
    <color name="textDisabled">#4A514D</color>

